// For format details, see https://aka.ms/devcontainer.json
{
  "name": "EZVIZ Patched Dev",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.13-bookworm",
  "postCreateCommand": "scripts/setup_devcontainer",
  "mounts": [
    "source=ezviz-ha-config,target=/config,type=volume"
  ],
  "runArgs": [
    "-e", "GIT_EDITOR=code --wait",
    "--network=host",
    "--cap-add=NET_RAW"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "github.vscode-pull-request-github",
        "ryanluker.vscode-coverage-gutters"
      ],
      "settings": {
        "files.eol": "\n",
        "editor.tabSize": 4,
        "editor.formatOnSave": true,
        "terminal.integrated.shell.linux": "/bin/zsh"
      }
    }
  },
  "forwardPorts": [8123, 9123],
  "portsAttributes": {
    "8123": {
      "label": "Home Assistant (default)",
      "onAutoForward": "notify"
    },
    "9123": {
      "label": "Home Assistant (alt)",
      "onAutoForward": "notify"
    }
  },
  "remoteUser": "root"
}
